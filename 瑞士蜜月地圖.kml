<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>🇨🇭 瑞士蜜月 2026/6/16–7/1</name>
  <description>行程地點總覽：住宿、餐廳、車站、景點攝影點</description>

  <!-- ===== 圖示樣式 ===== -->

  <!-- 住宿：藍色旅館 -->
  <Style id="hotel">
    <IconStyle>
      <color>ffDB6E2F</color>
      <scale>1.1</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/lodging.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ffDB6E2F</color><scale>0.9</scale></LabelStyle>
  </Style>

  <!-- 蜜月訂位餐廳：紅色 -->
  <Style id="restaurant-fancy">
    <IconStyle>
      <color>ff2222CC</color>
      <scale>1.0</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/dining.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ff2222CC</color><scale>0.9</scale></LabelStyle>
  </Style>

  <!-- 平價餐廳：橘色 -->
  <Style id="restaurant-casual">
    <IconStyle>
      <color>ff1478FF</color>
      <scale>0.9</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/dining.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ff1478FF</color><scale>0.85</scale></LabelStyle>
  </Style>

  <!-- 車站：紫色 -->
  <Style id="station">
    <IconStyle>
      <color>ffAA3DC8</color>
      <scale>1.1</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/rail.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ffAA3DC8</color><scale>0.9</scale></LabelStyle>
  </Style>

  <!-- 景點/攝影點：綠色 -->
  <Style id="photo">
    <IconStyle>
      <color>ff3DA858</color>
      <scale>1.0</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/camera.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ff3DA858</color><scale>0.85</scale></LabelStyle>
  </Style>

  <!-- 景點（特別重要）：深綠放大 -->
  <Style id="photo-star">
    <IconStyle>
      <color>ff1A7A32</color>
      <scale>1.3</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/camera.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ff1A7A32</color><scale>0.95</scale></LabelStyle>
  </Style>

